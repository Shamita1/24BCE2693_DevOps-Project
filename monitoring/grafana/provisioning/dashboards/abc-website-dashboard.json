{
  "title": "ABC Technologies Website - Monitoring",
  "timezone": "browser",
  "panels": [
    {
      "type": "timeseries",
      "title": "CPU Usage (%)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{ "target": "abc_website.system.cpu_percent" }]
    },
    {
      "type": "timeseries",
      "title": "Memory Usage (%)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [{ "target": "abc_website.system.memory_percent" }]
    },
    {
      "type": "timeseries",
      "title": "Network Usage (bytes)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "target": "abc_website.network.bytes_sent" },
        { "target": "abc_website.network.bytes_recv" }
      ]
    },
    {
      "type": "stat",
      "title": "HTTP Availability (1=Up, 0=Down)",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "targets": [{ "target": "abc_website.http.availability" }]
    },
    {
      "type": "stat",
      "title": "Uptime (seconds)",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "targets": [{ "target": "abc_website.uptime_seconds" }]
    }
  ],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s"
}
